# IB Gateway connection (must be running before backend starts)
# IB Gateway Live  → IBKR_PORT=4001
# IB Gateway Paper → IBKR_PORT=4002
# TWS Live         → IBKR_PORT=7496
# TWS Paper        → IBKR_PORT=7497
IBKR_HOST=127.0.0.1
IBKR_PORT=4001
IBKR_CLIENT_ID=1

# Redis (use redis://localhost:6379 for local dev without Docker)
REDIS_URL=redis://redis:6379
